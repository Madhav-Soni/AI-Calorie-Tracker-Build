{
  "expo": {
    "name": "AI Calorie Tracker",
    "slug": "ai-calorie-tracker",
    "scheme": "aicalorietracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#080813"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.madhav.aicalorietracker",
      "googleServicesFile": "./GoogleService-Info.plist",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to scan your food for calorie analysis",
        "NSPhotoLibraryUsageDescription": "Used to select food photos for analysis"
      }
    },
    "android": {
      "package": "com.madhav.aicalorietracker",
      "googleServicesFile": "./google-services.json",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080813"
      },
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES"
      ]
    },
    "plugins": [
      "expo-camera",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "e0795a97-ad12-4ea2-a534-9581eedf5bb3"
      }
    },
    "owner": "3000tonystark6969"
  }
}
