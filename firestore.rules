rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only access their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Meals subcollection with input validation
      match /meals/{mealId} {
        allow read, delete: if request.auth != null && request.auth.uid == userId;
        allow create, update: if request.auth != null 
                             && request.auth.uid == userId
                             && request.resource.data.name is string
                             && request.resource.data.name.size() > 0
                             && request.resource.data.name.size() <= 100
                             && request.resource.data.calories >= 0
                             && request.resource.data.calories <= 5000
                             && request.resource.data.protein >= 0
                             && request.resource.data.protein <= 500
                             && request.resource.data.carbs >= 0
                             && request.resource.data.carbs <= 500
                             && request.resource.data.fat >= 0
                             && request.resource.data.fat <= 300;
      }
    }
    
    // Block all other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
